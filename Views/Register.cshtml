@{
    ViewData["Title"] = "Account Registration";
}

<div class="container mt-5" style="max-width: 400px;">
    <div class="card shadow border-0 rounded-3 p-4">
        <h2 class="text-center mb-4 fw-bold">Register Admin</h2>
        
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center mb-3 py-2 small">@ViewBag.Error</div>
        }

        <form asp-controller="Account" asp-action="Register" method="post">
            <div class="mb-3">
                <label class="form-label font-weight-bold small text-secondary">Desired Username</label>
                <input type="text" name="username" class="form-control rounded-3" placeholder="Enter username..." required />
            </div>
            <div class="mb-3">
                <label class="form-label font-weight-bold small text-secondary">Secure Password</label>
                <input type="password" name="password" class="form-control rounded-3" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn btn-success w-100 mt-2 py-2 rounded-3 fw-bold">Create Administrator Account</button>
        </form>
        <div class="text-center mt-3 small">
            <a asp-controller="Account" asp-action="Login" class="text-decoration-none">Already have an account? Log In</a>
        </div>
    </div>
</div>
